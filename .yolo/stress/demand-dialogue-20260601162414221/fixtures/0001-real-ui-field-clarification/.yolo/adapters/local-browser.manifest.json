{
  "schema": "yolo.manifest.v1",
  "id": "local-browser",
  "kind": "acceptance_adapter",
  "description": "Local browser acceptance adapter for demand dialogue stress fixtures",
  "inputs": [
    "url",
    "prd"
  ],
  "outputs": [
    "acceptance_report"
  ],
  "commands": [
    {
      "command": "npm run accept"
    }
  ],
  "evidence": [
    "screenshot",
    "runtime_log"
  ],
  "capabilities": [
    "page_reachable",
    "screenshot",
    "runtime_errors"
  ],
  "applies_to": [
    "ui",
    "browser"
  ]
}
