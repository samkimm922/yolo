{
  "schema_version": "1.0",
  "last_reviewed": "2026-06-07",
  "purpose": "Machine-readable public SDK/API stability boundary. package.json exports, sdk.ts named exports, and createYoloSdk() namespaces must be classified here before they are treated as public.",
  "version_policy": {
    "stable": {
      "compatibility": "External projects may depend on this API.",
      "breaking_change": "Breaking changes require a major version bump or a compatibility shim with migration notes.",
      "deprecation": "Deprecations require documentation and at least one minor release of overlap before removal."
    },
    "stable_alias": {
      "compatibility": "Alias for a stable API. The target API owns behavior and compatibility.",
      "breaking_change": "Alias behavior must remain equivalent to its target while the alias exists.",
      "deprecation": "Alias removal requires migration notes to the canonical stable path."
    },
    "experimental": {
      "compatibility": "External projects may try this API, but shape and semantics can change before public beta.",
      "breaking_change": "Breaking changes are allowed in minor or beta releases when documented.",
      "deprecation": "Deprecations should name the replacement or explain why the API is being withdrawn."
    },
    "experimental_alias": {
      "compatibility": "Alias for an experimental API. The target API owns behavior and compatibility.",
      "breaking_change": "Alias behavior may change when its experimental target changes.",
      "deprecation": "Alias removal should name the canonical experimental path."
    },
    "compatibility": {
      "compatibility": "Legacy public surface kept to avoid breaking existing local usage.",
      "breaking_change": "Do not add new behavior here. Move implementation under src/ and keep this as a shim where possible.",
      "deprecation": "Removal requires a replacement path and migration notes."
    },
    "internal": {
      "compatibility": "No public compatibility promise.",
      "breaking_change": "Can change at any time as long as package exports, bins, and documented SDK APIs stay compatible.",
      "deprecation": "No deprecation window required unless it has leaked into package exports."
    }
  },
  "package_exports": [
