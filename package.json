{
  "name": "yolo",
  "version": "0.1.0",
  "private": true,
  "description": "YOLO — 自动化 coding 管道（PRD → 修复 → 闸门 → 提交）",
  "type": "module",
  "files": [
    "dist/bin/",
    "dist/src/",
    "dist/lib/",
    "dist/tools/",
    "dist/fixtures/",
    "dist/schemas/",
    "dist/docs/",
    "dist/*.js",
    "dist/*.d.ts",
    "dist/*.js.map",
    "dist/package.json",
    "dist/README.md",
    "dist/CHANGELOG.md",
    "dist/config.yaml",
    "dist/config.example.yaml",
    "dist/settings-minimal.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": "./dist/sdk.js",
    "./agents": "./dist/src/agents/presets.js",
    "./pi": "./dist/src/agents/pi.js",
    "./pi-runtimes": "./dist/src/runtime/pi-runtimes.js",
    "./runtime": "./dist/src/runtime/runner-runtime.js",
    "./runtime/adapters": "./dist/src/runtime/adapters/agent-contract.js",
    "./runtime/adapter-evidence": "./dist/src/runtime/adapters/evidence-collector.js",
    "./runtime/progress-ui-evidence": "./dist/src/runtime/progress/ui-evidence.js",
    "./core/bootstrap": "./dist/src/core/bootstrap.js",
    "./core/setup": "./dist/src/core/setup.js",
    "./core/init-smoke": "./dist/src/core/init-smoke.js",
    "./core/config": "./dist/src/core/config.js",
    "./core/paths": "./dist/src/core/paths.js",
    "./prd/migration": "./dist/src/prd/migration.js",
    "./prd/preflight": "./dist/src/prd/preflight.js",
    "./spec/lifecycle": "./dist/src/spec/lifecycle.js",
    "./spec/traceability": "./dist/src/spec/traceability.js",
    "./evidence/ledger": "./dist/src/evidence/ledger.js",
    "./evidence/report": "./dist/src/evidence/report.js",
    "./review/findings": "./dist/src/review/findings.js",
    "./workflows": "./dist/src/workflows/registry.js",
    "./workflows/install": "./dist/src/workflows/install.js",
    "./fixtures": "./dist/src/fixtures/registry.js",
    "./fixtures/harness": "./dist/src/fixtures/harness.js",
    "./release/readiness": "./dist/src/release/readiness.js",
    "./release/pack-smoke": "./dist/src/release/pack-smoke.js",
    "./release/hardening-drill": "./dist/src/release/hardening-drill.js",
    "./release/decision-gate": "./dist/src/release/decision-gate.js",
    "./release/change-provenance": "./dist/src/release/change-provenance.js",
    "./release/clean-environment-verify": "./dist/src/release/clean-environment-verify.js",
    "./release/dogfood-matrix": "./dist/src/release/dogfood-matrix.js",
    "./release/operator-state": "./dist/src/release/operator-state.js",
    "./release/operator-runbook": "./dist/src/release/operator-runbook.js",
    "./release/post-release-audit": "./dist/src/release/post-release-audit.js",
    "./release/stable-graduation": "./dist/src/release/stable-graduation.js",
    "./release/manual-external-release": "./dist/src/release/manual-external-release.js",
    "./release/agent-integration-doctor": "./dist/src/release/agent-integration-doctor.js",
    "./release/real-project-dogfood": "./dist/src/release/real-project-dogfood.js",
    "./release/pi-execution-drill": "./dist/src/release/pi-execution-drill.js",
    "./release/runtime-boundary-decision": "./dist/src/release/runtime-boundary-decision.js",
    "./release/public-beta-evidence": "./dist/src/release/public-beta-evidence.js",
    "./release/real-project-dogfood-pack": "./dist/src/release/real-project-dogfood-pack.js",
    "./release/experience-pack-audit": "./dist/src/release/experience-pack-audit.js",
    "./release/nontechnical-ux-doctor": "./dist/src/release/nontechnical-ux-doctor.js",
    "./eval/benchmark": "./dist/src/eval/benchmark.js",
    "./pm": "./dist/src/pm/index.js",
    "./audit-to-prd": "./dist/src/prd/audit-to-prd.js",
    "./prd-migrate-gates": "./dist/src/prd/migration.js",
    "./prd-preflight": "./dist/src/prd/preflight.js",
    "./validate-prd": "./dist/src/prd/validate.js",
    "./contract": "./dist/src/prd/contract.js",
    "./scanner": "./dist/src/review/scanner.js",
    "./config": "./dist/src/core/config.js"
  },
  "bin": {
    "yolo": "./dist/bin/yolo.js",
    "yolo-gate": "./dist/bin/yolo-gate.js",
    "yolo-prd-migrate-gates": "./dist/bin/yolo-prd-migrate-gates.js",
    "yolo-prd-preflight": "./dist/bin/yolo-prd-preflight.js",
    "yolo-pi": "./dist/bin/yolo-pi.js",
    "yolo-prompt": "./dist/bin/yolo-prompt.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsx scripts/copy-runtime-assets.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && node --import tsx scripts/typecheck-guard.ts",
    "runner": "npm run build --silent && node ./dist/runner.js",
    "pi": "npm run build --silent && node ./dist/bin/yolo-pi.js",
    "gate": "npm run build --silent && node ./dist/gate.js",
    "contract": "npm run build --silent && node ./dist/src/prd/contract.js",
    "prompt": "npm run build --silent && node ./dist/prompt.js",
    "pm": "npm run build --silent && node ./dist/src/pm/index.js",
    "migrate-gates": "npm run build --silent && node ./dist/bin/yolo-prd-migrate-gates.js",
    "preflight": "npm run build --silent && node ./dist/bin/yolo-prd-preflight.js --check-all",
    "review": "npm run build --silent && node ./dist/src/cli/review.js",
    "learn": "npm run build --silent && node ./dist/learn.js",
    "audit-to-prd": "npm run build --silent && node ./dist/src/prd/audit-to-prd.js",
    "progress": "npm run build --silent && node ./dist/src/runtime/progress/server.js",
    "generate-tree": "npm run build --silent && node ./dist/src/runtime/devtools/generate-tree.js",
    "memory:refresh": "npm run build --silent && node ./dist/src/runtime/devtools/memory-center.js --legacy-pointers",
    "test": "npm run build --silent && node --import tsx --test __tests__/*.test.ts",
    "verify": "npm run typecheck --silent && npm run test --silent && node --import tsx scripts/source-grep-meta.ts && node --import tsx scripts/ci-guard.ts && npm run preflight --silent && node -e \"import {config} from'./dist/lib/config.js';process.exit(config.version==='2.0'?0:1)\"",
    "prepack": "npm run build --silent",
    "lint:fix": "echo 'use project root lint:fix for src/'",
    "clean": "node -e \"const{existsSync,readFileSync,writeFileSync}=require('fs');const{join}=require('path');['.yolo/state/events.jsonl','.yolo/state/changes.jsonl','.yolo/state/runs.jsonl'].forEach(f=>{const p=join(process.cwd(),f);if(existsSync(p)){const c=readFileSync(p,'utf8').split('\\n').filter(Boolean).slice(-50);writeFileSync(p,c.join('\\n')+'\\n')}});console.log('state cleaned')\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "automation",
    "code-fix",
    "gate-check",
    "prd"
  ],
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "main": "./dist/sdk.js",
  "types": "./dist/sdk.d.ts",
  "dependencies": {
    "ajv": "^8.20.0"
  }
}
