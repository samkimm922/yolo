{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://yolo.dev/schemas/evidence-ledger-v1.schema.json",
  "title": "YOLO Evidence Ledger v1",
  "oneOf": [
    { "$ref": "#/$defs/ledgerEvent" },
    { "$ref": "#/$defs/evidenceArtifact" }
  ],
  "$defs": {
    "ledgerEvent": {
      "type": "object",
      "required": ["schema_version", "schema", "ts", "ledger", "event", "source", "prev_hash", "record_hash"],
      "oneOf": [
        { "required": ["record_sig"] },
        {
          "required": ["evidence_security"],
          "properties": {
            "evidence_security": {
              "type": "object",
              "required": ["mode", "production_ready", "notice"],
              "properties": {
                "mode": { "const": "development_unsigned" },
                "production_ready": { "const": false },
                "notice": { "const": "UNSIGNED EVIDENCE: NOT VALID FOR PRODUCTION ACCEPTANCE" }
              }
            }
          }
        }
      ],
      "properties": {
        "schema_version": { "const": "1.0" },
        "schema": { "const": "yolo.ledger.event.v1" },
        "ts": { "type": "string", "minLength": 1 },
        "ledger": { "enum": ["state", "run", "artifact", "custom"] },
        "event": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "run_id": { "type": "string" },
        "task_id": { "type": "string" },
        "prd_id": { "type": "string" },
        "status": { "type": "string" },
        "evidence_file": { "type": "string" },
        "artifact_type": { "type": "string" },
        "code": { "type": "string" },
        "message": { "type": "string" },
        "suggested_fix": { "type": "string" },
        "prev_hash": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ],
          "description": "Hash of the previous ledger record. null for the genesis record."
        },
        "record_hash": { "type": "string", "minLength": 1, "description": "SHA-256 hash of the canonical record payload." },
        "record_sig": { "type": "string", "minLength": 1, "description": "HMAC-SHA256 signature of record_hash and prev_hash." }
      },
      "additionalProperties": true
    },
    "evidenceArtifact": {
      "type": "object",
      "required": ["schema_version", "schema", "artifact_type", "generated_at", "source", "artifact_digest"],
      "properties": {
        "schema_version": { "const": "1.0" },
        "schema": { "const": "yolo.evidence.artifact.v1" },
        "artifact_type": { "type": "string", "minLength": 1 },
        "generated_at": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "status": { "type": "string" },
        "run_id": { "type": "string" },
        "task_id": { "type": "string" },
        "prd_id": { "type": "string" },
        "evidence_file": { "type": "string" },
        "code": { "type": "string" },
        "message": { "type": "string" },
        "suggested_fix": { "type": "string" },
        "artifact_digest": { "type": "string", "minLength": 1, "description": "SHA-256 hash of the canonical artifact payload." }
      },
      "additionalProperties": true
    }
  }
}
