node_modules/
dist/
.DS_Store
__pycache__/
*.py[cod]

# Local agent/runtime artifacts.
.agents/

# Append-only runtime state and generated evidence.
.yolo/
.yolo/state/
.yolo/skills/
state/*.jsonl
state/archive/
state/runtime/
state/evidence/

# Signing keys — NEVER commit. Verification public keys are project-rooted
# runtime secrets; private keys must live outside the repo (CI/external). A
# committed private key voids every signature guarantee (anyone with the repo
# could forge evidence/approvals).
state/keys/
*.key
*.pem

# Stress fixtures and demand evidence are runtime state; keep them on disk only.

# Local logs and scratch files.
logs/
tmp/
*.log

# Local session handoff files (runtime artifacts, not committed).
docs/memory/
learned-rules.json
scripts/yolo/closed-loop/retry-count.json
SESSION.md
SNAPSHOT.md
DELIVERY_LOG.md
.claude/worktrees/
