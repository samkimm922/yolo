node_modules/
dist/
.DS_Store
__pycache__/
*.py[cod]

# Local agent/runtime artifacts.
.agents/

# Append-only runtime state and generated evidence.
.yolo/state/
state/*.jsonl
state/archive/
state/runtime/
state/evidence/

# Stress fixtures may create nested Git repositories to test boundary handling.
# Track fixture files, but never parent-repo commit their internal Git metadata.
.yolo/stress/**/.git/
.yolo/stress/**/fixtures/*-real-boundary-mutation-probe/
.yolo/stress/manual-boundary-probe-*/fixture/

# Local logs and scratch files.
logs/
tmp/
*.log

# Local session handoff files.
DELIVERY_LOG.md
SESSION.md
SNAPSHOT.md
